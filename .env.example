# Neon PostgreSQL connection (provisioned via Vercel Marketplace integration — D-12)
# Local dev: paste from Neon dashboard → Connection Details
# Production: auto-injected by Vercel
DATABASE_URL=postgres://user:pass@host.neon.tech/dbname?sslmode=require

# NextAuth v5 (required for /login OAuth flow)
# Generate AUTH_SECRET locally: openssl rand -base64 32
AUTH_SECRET=
# Production: https://we-clinica-financeiro.vercel.app — preview auto-uses VERCEL_URL
AUTH_URL=http://localhost:3000
# From Google Cloud Console → Credentials → OAuth 2.0 Client ID (Web application)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
